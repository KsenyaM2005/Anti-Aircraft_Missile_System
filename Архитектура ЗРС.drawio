        <UserObject label="function processStep(dt):&#xa;    // 1. Получение замеров от среды (цели и ракеты)&#xa;    measurements = receiveFromEnvironment()&#xa;    &#xa;    // 2. Получение априорной информации о траектории ЗУР&#xa;    priorInfoList = receivePriorMissileInfo()&#xa;    &#xa;    // 3. Создание/обновление треков ракет по априорной информации&#xa;    for info in priorInfoList:&#xa;        track = findTrackByMissileId(info.missileId)&#xa;        if track exists:&#xa;            track.confidence += CONFIDENCE_STEP&#xa;        else:&#xa;            newTrack = new Track()&#xa;            newTrack.type = MISSILE&#xa;            newTrack.missileId = info.missileId&#xa;            newTrack.state = [info.startPos, info.startVel]&#xa;            newTrack.confidence = info.confidence&#xa;            tracks.add(newTrack)&#xa;    &#xa;    // 4. Предсказание состояния всех треков&#xa;    for track in tracks:&#xa;        track.predict(dt)&#xa;    &#xa;    // 5. Формирование стробов&#xa;    gates = association.createGates(tracks, measurements)&#xa;    &#xa;    // 6. Построение матрицы стоимостей&#xa;    costMatrix = association.buildCostMatrix(tracks, measurements, gates)&#xa;    &#xa;    // 7. Решение задачи назначения&#xa;    assignments = association.hungarianAlgorithm(costMatrix)&#xa;    &#xa;    // 8. Обновление треков по назначениям&#xa;    for assignment in assignments:&#xa;        if assignment.track and assignment.measurement:&#xa;            assignment.track.update(assignment.measurement)&#xa;        else if assignment.track and not assignment.measurement:&#xa;            assignment.track.missedUpdates++&#xa;    &#xa;    // 9. Создание новых треков целей&#xa;    assignedMeasures = getAssignedMeasures(assignments)&#xa;    for measure in measurements:&#xa;        if measure not in assignedMeasures:&#xa;            newTrack = new Track()&#xa;            newTrack.type = TARGET&#xa;            newTrack.state = measure.cartesian&#xa;            tracks.add(newTrack)&#xa;    &#xa;    // 10. Обновление уверенности ракетных треков&#xa;    for track in tracks:&#xa;        if track.type == MISSILE:&#xa;            if track.missedUpdates == 0:&#xa;                track.confidence += CONFIDENCE_STEP&#xa;            else:&#xa;                track.confidence -= CONFIDENCE_DECAY * dt&#xa;            &#xa;            if track.confidence &gt; CONFIRM_THRESHOLD:&#xa;                track.status = CONFIRMED&#xa;            elif track.confidence &lt;= 0:&#xa;                tracks.remove(track)&#xa;    &#xa;    // 11. Удаление потерянных треков&#xa;    for track in tracks:&#xa;        if track.missedUpdates &gt; MISS_THRESHOLD:&#xa;            tracks.remove(track)&#xa;    &#xa;    // 12. Выдача треков&#xa;    outputTargetTracks()&#xa;    outputMissileTracks()" link="function processStep(dt):&#xa;    // 1. Получение замеров от среды (цели и ракеты)&#xa;    measurements = receiveFromEnvironment()&#xa;    &#xa;    // 2. Получение априорной информации от ПБУ/ПУ&#xa;    priorInfoList = receivePriorMissileInfo()&#xa;    &#xa;    // 3. Создание/обновление треков ракет по априорной информации&#xa;    for info in priorInfoList:&#xa;        track = findTrackByMissileId(info.missileId)&#xa;        if track exists:&#xa;            track.confidence += CONFIDENCE_STEP&#xa;        else:&#xa;            newTrack = new Track()&#xa;            newTrack.type = MISSILE&#xa;            newTrack.missileId = info.missileId&#xa;            newTrack.state = [info.startPos, info.startVel]&#xa;            newTrack.confidence = info.confidence&#xa;            tracks.add(newTrack)&#xa;    &#xa;    // 4. Предсказание состояния всех треков&#xa;    for track in tracks:&#xa;        track.predict(dt)&#xa;    &#xa;    // 5. Формирование стробов&#xa;    gates = association.createGates(tracks, measurements)&#xa;    &#xa;    // 6. Построение матрицы стоимостей&#xa;    costMatrix = association.buildCostMatrix(tracks, measurements, gates)&#xa;    &#xa;    // 7. Решение задачи назначения (венгерский алгоритм)&#xa;    assignments = association.hungarianAlgorithm(costMatrix)&#xa;    &#xa;    // 8. Обновление треков по назначениям&#xa;    for assignment in assignments:&#xa;        if assignment.track and assignment.measurement:&#xa;            assignment.track.update(assignment.measurement)&#xa;        else if assignment.track and not assignment.measurement:&#xa;            assignment.track.missedUpdates++&#xa;    &#xa;    // 9. Создание новых треков целей&#xa;    assignedMeasures = getAssignedMeasures(assignments)&#xa;    for measure in measurements:&#xa;        if measure not in assignedMeasures:&#xa;            newTrack = new Track()&#xa;            newTrack.type = TARGET&#xa;            newTrack.state = measure.cartesian&#xa;            tracks.add(newTrack)&#xa;    &#xa;    // 10. Обновление уверенности ракетных треков&#xa;    for track in tracks:&#xa;        if track.type == MISSILE:&#xa;            if track.missedUpdates == 0:&#xa;                track.confidence += CONFIDENCE_STEP&#xa;            else:&#xa;                track.confidence -= CONFIDENCE_DECAY * dt&#xa;            &#xa;            if track.confidence &gt; CONFIRM_THRESHOLD:&#xa;                track.status = CONFIRMED&#xa;            elif track.confidence &lt;= 0:&#xa;                tracks.remove(track)&#xa;    &#xa;    // 11. Удаление потерянных треков&#xa;    for track in tracks:&#xa;        if track.missedUpdates &gt; MISS_THRESHOLD:&#xa;            tracks.remove(track)&#xa;    &#xa;    // 12. Выдача треков&#xa;    outputTargetTracks()&#xa;    outputMissileTracks()" id="3DftqjG71_OxN9xCZghh-93">
